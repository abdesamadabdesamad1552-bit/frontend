# ━━━ Backend API (geo only) ━━━
NEXT_PUBLIC_API_URL=http://localhost:4000

# ━━━ Orders — saved directly from Next.js (required in production) ━━━
DATABASE_URL=postgresql://postgres:PASSWORD@naqabeauty_database:5432/naqabeauty?sslmode=disable

# ━━━ Order Webhook → Make.com → Google Sheets (optional) ━━━
# Make.com: Custom Webhook module URL (POST JSON). Map fields to Google Sheets "Add a row".
# Alternative: deploy scripts/google-apps-script-webhook.js as Web App and paste that URL.
GOOGLE_SHEETS_WEBHOOK_URL=

# ━━━ Analytics & Tracking Pixels ━━━
# Leave blank to disable a specific pixel.
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=
