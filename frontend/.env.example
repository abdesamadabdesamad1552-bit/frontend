# ━━━ Backend API (geo only) ━━━
NEXT_PUBLIC_API_URL=http://localhost:4000

# ━━━ Orders — saved directly from Next.js (required in production) ━━━
DATABASE_URL=postgresql://postgres:PASSWORD@naqabeauty_database:5432/naqabeauty?sslmode=disable

# ━━━ Order Webhook → Make.com → Google Sheets (optional) ━━━
# Make.com: Custom Webhook module URL (POST JSON). Map fields to Google Sheets "Add a row".
# Alternative: deploy scripts/google-apps-script-webhook.js as Web App and paste that URL.
GOOGLE_SHEETS_WEBHOOK_URL=

# ━━━ Analytics & Tracking Pixels ━━━
# Leave blank to disable a specific pixel.
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=

# ━━━ TikTok Events API (server-side "CompletePayment" on order confirm) ━━━
# Both this AND NEXT_PUBLIC_TIKTOK_PIXEL_ID above must be set for the event to fire.
# Get the token from TikTok Events Manager → your Pixel → Settings → Events API → Generate Access Token.
TIKTOK_ACCESS_TOKEN=

# ━━━ Checkout — Stripe (card + Apple Pay). See docs/checkout/api/stripe.md ━━━
# Leave blank to keep card/Apple Pay showing "قيد التفعيل" and COD as the only method.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ━━━ Checkout — Tabby (KSA/UAE BNPL). See docs/checkout/api/tabby.md ━━━
TABBY_SECRET_KEY=
TABBY_MERCHANT_CODE=

# ━━━ Checkout — Tamara (KSA BNPL). See docs/checkout/api/tamara.md ━━━
TAMARA_API_TOKEN=
TAMARA_NOTIFICATION_TOKEN=
# TAMARA_ENV=sandbox   # uncomment while testing against Tamara's sandbox

# ━━━ Checkout — shared ━━━
NEXT_PUBLIC_SITE_URL=https://naqabeauty.store
