# ━━━ Server ━━━
PORT=4000
NODE_ENV=development

# ━━━ CORS (comma-separated for multiple origins) ━━━
FRONTEND_URL=http://localhost:3000

# ━━━ Google Sheets Webhook ━━━
GOOGLE_SHEETS_WEBHOOK_URL=

# ━━━ MaxMind GeoIP ━━━
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ━━━ GeoIP Service (fallback) ━━━
GEOIP_API_KEY=
