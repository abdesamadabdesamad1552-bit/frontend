# ━━━ Server ━━━
PORT=4000
NODE_ENV=development

# ━━━ CORS (comma-separated for multiple origins) ━━━
# Production (Easypanel) — copy Internal Connection URL from database → Credentials
# Example shape (use YOUR password from Credentials, not a placeholder):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@naqabeauty_database:5432/naqabeauty?sslmode=disable
# Dev origins are allowed automatically when NODE_ENV=development
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ━━━ PostgreSQL Database ━━━
DATABASE_URL=postgresql://user:password@localhost:5432/naqabeauty

# ━━━ Order Webhook → Make.com → Google Sheets (optional) ━━━
# Make.com: Custom Webhook module URL (POST JSON). Map fields to Google Sheets "Add a row".
# Alternative: deploy scripts/google-apps-script-webhook.js as Web App and paste that URL.
GOOGLE_SHEETS_WEBHOOK_URL=

# ━━━ MaxMind GeoIP ━━━
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ━━━ GeoIP Service (fallback) ━━━
GEOIP_API_KEY=
